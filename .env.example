# =====================================================================
#  نظام العقود الموحد — متغيرات البيئة للإنتاج
#  Copy this file to .env and fill in ALL values before deploying.
#
#    cp .env.example .env && nano .env
# =====================================================================

# ── Server ────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
TZ=Asia/Riyadh

# ── Database ──────────────────────────────────────────────────────────
# "db" = the docker-compose service name (internal Docker hostname).
# Do NOT use "localhost" — the app container cannot reach it that way.
POSTGRES_DB=unified_db
POSTGRES_USER=unified_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

DATABASE_URL=postgresql://unified_user:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/unified_db

# ── Authentication (REQUIRED — server refuses to start without this) ──
# Generate a strong secret (min 32 chars, ideally 64):
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_USE_STRONG_RANDOM_64_CHAR_SECRET

# ── Admin Account ─────────────────────────────────────────────────────
# Used only if admin user does not already exist (e.g. fresh DB, no seed).
# Minimum 12 characters. Change the admin password immediately after first login.
ADMIN_DEFAULT_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# ── File Uploads ──────────────────────────────────────────────────────
# Where attachments are stored inside the container.
# Mounted as the "unified_uploads" Docker volume — do not change unless needed.
# UPLOAD_DIR=/app/uploads

# Max single-file upload size in MB.
# Must match nginx client_max_body_size (nginx.conf default: 110m).
# MAX_ATTACHMENT_SIZE_MB=100

# ── CORS (optional) ───────────────────────────────────────────────────
# Only needed when frontend and backend are on different origins.
# With Nginx same-origin reverse proxy this is NOT required.
# ALLOWED_ORIGINS=https://your-domain.com
